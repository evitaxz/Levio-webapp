# Levio Backend Environment Variables — copy this file to .env and fill in values

OPENAI_API_KEY=sk-...
JWT_SECRET=random-string-at-least-32-characters
VAPID_PUBLIC_KEY=generated-by-web-push
VAPID_PRIVATE_KEY=generated-by-web-push
VAPID_EMAIL=mailto:your@email.com
FRONTEND_URL=https://your-app.vercel.app
PORT=3001
